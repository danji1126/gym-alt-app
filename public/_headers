# Cloudflare Pages Custom Headers
# Ref: docs/04-reports/security-review.md M-1
#
# CSP — 정적 export + 외부 이미지 1개 도메인(github raw)만 허용.
# Next.js hydration script는 inline 부트 데이터를 사용하므로 'unsafe-inline' 필요.
# (정적 export는 nonce 미적용)

/*
  Content-Security-Policy: default-src 'self'; img-src 'self' https://raw.githubusercontent.com data:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=63072000; includeSubDomains
  Permissions-Policy: camera=(), microphone=(), geolocation=()
